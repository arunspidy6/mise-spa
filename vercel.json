{
  "alias": ["mise-spa.vercel.app"],
  "functions": {
    "api/generate-recipe.ts": {
      "runtime": "@vercel/node@3.2.23",
      "maxDuration": 60
    },
    "api/classify-ingredient.ts": {
      "runtime": "@vercel/node@3.2.23",
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
